{
  "$schema": "https://swc.rs/schema.json",
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": false,
      "decorators": false
    },
    "target": "es2022",
    "keepClassNames": true,
    "externalHelpers": false
  },
  "module": {
    "type": "es6"
  },
  "sourceMaps": false
}
